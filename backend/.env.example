# Deployment environment. Set to "production" on Railway/Render — this
# triggers fail-fast validation that no required value is missing or still
# pointing at localhost (see backend/config.py).
ENVIRONMENT=development

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Database (Neon)
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Better Auth
BETTER_AUTH_SECRET=your-secret-here
BETTER_AUTH_URL=http://localhost:3000

# Upstash Redis
UPSTASH_REDIS_URL=https://your-redis.upstash.io
UPSTASH_REDIS_TOKEN=AX...

# Microsoft (Azure AD)
MICROSOFT_CLIENT_ID=your-client-id
MICROSOFT_CLIENT_SECRET=your-client-secret
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/auth/microsoft/callback

# Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your-fernet-key

# Frontend
FRONTEND_URL=http://localhost:3000

# Graph / Google API hard request timeout (seconds). HTTP-client-level —
# enforced on O365's Connection.timeout and googleapiclient's httplib2.Http
# instance, since the underlying calls are synchronous and asyncio.wait_for
# can't preempt them. Tune from observed tool durations.
ORBIT_GRAPH_TIMEOUT_S=30

# Side-channel tool_progress SSE event fires when a tool call hasn't
# completed within this many seconds. Must be lower than ORBIT_GRAPH_TIMEOUT_S
# so the user sees activity before the call would otherwise time out.
ORBIT_TOOL_PROGRESS_THRESHOLD_S=5
