# Backend API (Railway in prod, localhost in dev)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Better Auth (server + client must agree on these)
# In production, set BOTH to your full Vercel URL (no trailing slash).
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-a-long-random-string

# Optional: extra origins to trust for CSRF-style origin checks.
# Comma-separated. Useful for Vercel preview deploys or custom domains.
# BETTER_AUTH_URL + NEXT_PUBLIC_BETTER_AUTH_URL + localhost:3000 are
# always trusted automatically.
# TRUSTED_ORIGINS=https://orbit-preview-abc.vercel.app,https://orbit.example.com

# Neon Postgres — same connection string the backend uses.
# Drizzle reads this for migrations; Better Auth reads it via the Drizzle adapter.
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Social sign-in (Google + Microsoft). These reuse the same OAuth app
# registrations the backend uses for Outlook/Calendar/Tasks data scopes.
# Only the redirect URI differs (see Console steps below).
#
# Server-side credentials (NOT NEXT_PUBLIC — keep secret):
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
#
# Client-side feature flags. Set =1 (any truthy value) to show the
# corresponding social button on the login page. Without these, the
# button is hidden in production builds even if the server-side
# credentials are set.
NEXT_PUBLIC_GOOGLE_ENABLED=1
NEXT_PUBLIC_MICROSOFT_ENABLED=1
#
# OAuth redirect URIs to register in the provider consoles for THIS
# deployment (in addition to the backend's existing ones):
#
#   Google Cloud Console → APIs & Services → Credentials → your OAuth
#   client → Authorized redirect URIs → add:
#     https://<your-vercel-url>/api/auth/callback/google
#
#   Azure Portal → App registrations → your app → Authentication →
#   Redirect URIs → add (under Web platform):
#     https://<your-vercel-url>/api/auth/callback/microsoft
#
# Local dev redirect URIs (also register these once for `npm run dev`):
#   http://localhost:3000/api/auth/callback/google
#   http://localhost:3000/api/auth/callback/microsoft
